
import React, { useState, useCallback, useRef, useEffect } from 'react';
import { motion, AnimatePresence } from 'motion/react';
import { MoldingRecord, ChatMessage, ImprovementData, UserProfile, AnalysisHistoryRecord } from './types';
import DataEntry from './components/DataEntry';
import Visualizations from './components/Visualizations';
import AdminDashboard from './components/AdminDashboard';
import Auth from './components/Auth';
import { analyzeMoldingData, chatWithExpert } from './services/gemini';
import ReactMarkdown from 'react-markdown';
import { translations, Language } from './translations';
import { Toaster, toast } from 'sonner';
import { 
  auth, 
  onAuthStateChanged, 
  db, 
  doc, 
  getDoc, 
  setDoc, 
  collection, 
  addDoc, 
  updateDoc,
  serverTimestamp,
  storage,
  ref,
  uploadBytes,
  getDownloadURL,
  FirebaseUser,
  handleFirestoreError,
  OperationType
} from './firebase';
import { getDocFromServer } from 'firebase/firestore';
import { 
  LogOut, 
  LayoutDashboard, 
  Database, 
  User as UserIcon, 
  Settings, 
  Menu, 
  X, 
  Home, 
  BarChart3, 
  Zap, 
  Sun, 
  Moon,
  ChevronLeft,
  ChevronRight,
  CheckCircle,
  AlertCircle,
  FileText
} from 'lucide-react';

const App: React.FC = () => {
  const [lang, setLang] = useState<Language>('vi');
  const t = translations[lang];

  useEffect(() => {
    async function testConnection() {
      try {
        await getDocFromServer(doc(db, 'test', 'connection'));
      } catch (error) {
        if(error instanceof Error && error.message.includes('the client is offline')) {
          console.error("Please check your Firebase configuration. ");
        }
      }
    }
    testConnection();
  }, []);
  
  const [user, setUser] = useState<FirebaseUser | null>(null);
  const [userProfile, setUserProfile] = useState<UserProfile | null>(null);
  const [authLoading, setAuthLoading] = useState(true);
  const [view, setView] = useState<'app' | 'admin'>('app');

  const [data, setData] = useState<MoldingRecord[]>([]);
  const [analysis, setAnalysis] = useState<string | null>(null);
  const [improvementData, setImprovementData] = useState<ImprovementData | null>(null);
  const [productName, setProductName] = useState<string>('');
  const [loading, setLoading] = useState(false);
  const [error, setError] = useState<string | null>(null);
  
  const [chatMessages, setChatMessages] = useState<ChatMessage[]>([]);
  const [chatInput, setChatInput] = useState('');
  const [chatLoading, setChatLoading] = useState(false);
  const chatEndRef = useRef<HTMLDivElement>(null);
  const [rawContext, setRawContext] = useState<string>('');
  const [isDarkMode, setIsDarkMode] = useState(true);
  const [showConfirmModal, setShowConfirmModal] = useState(false);
  const [currentRecordId, setCurrentRecordId] = useState<string | null>(null);
  const [isConfirmed, setIsConfirmed] = useState(false);
  const [isSaving, setIsSaving] = useState(false);
  const [isSidebarOpen, setIsSidebarOpen] = useState(false);

  useEffect(() => {
    const unsubscribe = onAuthStateChanged(auth, async (firebaseUser) => {
      setUser(firebaseUser);
      if (firebaseUser) {
        try {
          const userDoc = await getDoc(doc(db, 'users', firebaseUser.uid));
          if (userDoc.exists()) {
            setUserProfile(userDoc.data() as UserProfile);
          } else {
            const newProfile: UserProfile = {
              uid: firebaseUser.uid,
              email: firebaseUser.email || '',
              displayName: firebaseUser.displayName || '',
              photoURL: firebaseUser.photoURL || '',
              role: firebaseUser.email === 'xiemtoiyeuquehuong@gmail.com' ? 'admin' : 'user',
              createdAt: serverTimestamp()
            };
            await setDoc(doc(db, 'users', firebaseUser.uid), newProfile);
            setUserProfile(newProfile);
          }
        } catch (error) {
          handleFirestoreError(error, OperationType.GET, 'users/' + firebaseUser.uid);
        }
      } else {
        setUserProfile(null);
        setView('app');
        reset();
      }
      setAuthLoading(false);
    });
    return () => unsubscribe();
  }, []);

  useEffect(() => {
    if (isDarkMode) {
      document.body.classList.remove('light-mode');
    } else {
      document.body.classList.add('light-mode');
    }
  }, [isDarkMode]);

  const resizeImage = (base64Str: string, maxWidth = 2048, maxHeight = 2048): Promise<string> => {
    return new Promise((resolve) => {
      const img = new Image();
      img.src = base64Str;
      img.onload = () => {
        const canvas = document.createElement('canvas');
        let width = img.width;
        let height = img.height;

        if (width > height) {
          if (width > maxWidth) {
            height *= maxWidth / width;
            width = maxWidth;
          }
        } else {
          if (height > maxHeight) {
            width *= maxHeight / height;
            height = maxHeight;
          }
        }

        canvas.width = width;
        canvas.height = height;
        const ctx = canvas.getContext('2d');
        ctx?.drawImage(img, 0, 0, width, height);
        resolve(canvas.toDataURL('image/jpeg', 0.9));
      };
      img.onerror = () => resolve(base64Str);
    });
  };

  const handleDataLoaded = useCallback(async (
    loadedData: MoldingRecord[], 
    notes?: string,
    imageBase64?: string,
    inputMethod: string = 'Excel/Manual',
    department?: string,
    machineCode?: string,
    imageNotes?: string
  ) => {
    if (!user || loading) return;

    let processedImage = imageBase64;
    if (imageBase64 && imageBase64.length > 2000000) { // If > 2MB, resize
      processedImage = await resizeImage(imageBase64);
    }

    // Update user profile with department if provided
    if (department && department !== userProfile?.department) {
      try {
        const userRef = doc(db, 'users', user.uid);
        await setDoc(userRef, { department }, { merge: true });
        setUserProfile(prev => prev ? { ...prev, department } : null);
      } catch (error) {
        handleFirestoreError(error, OperationType.UPDATE, 'users');
      }
    }

    setData(loadedData);
    setProductName(loadedData[0]?.product || '');
    setLoading(true);
    setError(null);
    setAnalysis(null);
    setImprovementData(null);
    setChatMessages([]);
    setIsConfirmed(false);
    setCurrentRecordId(null);
    
    try {
      const startTime = Date.now();
      setRawContext(JSON.stringify(loadedData, null, 2) + (notes ? `\nNotes: ${notes}` : ''));

      // Create initial processing record
      let recordId = '';
      try {
        const docRef = await addDoc(collection(db, 'analysis_history'), {
          userId: user.uid,
          userName: user.displayName || 'Anonymous',
          userEmail: user.email || '',
          department: department || userProfile?.department || '',
          createdAt: serverTimestamp(),
          status: 'processing',
          productName: loadedData[0]?.product || 'N/A',
          machineCode: machineCode || '',
        });
        recordId = docRef.id;
        setCurrentRecordId(recordId);
      } catch (error) {
        console.error("Failed to create history record:", error);
        // We continue even if history record fails, but we won't be able to update it later
      }

      try {
        // Start AI analysis and image upload in parallel
        const analysisPromise = analyzeMoldingData(loadedData, notes, processedImage, lang, imageNotes);
        
        let imageUploadPromise = Promise.resolve('');
        if (processedImage) {
          imageUploadPromise = (async () => {
            try {
              // More efficient base64 to blob conversion
              const parts = processedImage.split(',');
              const mime = parts[0].match(/:(.*?);/)?.[1] || 'image/jpeg';
              const bstr = atob(parts[1]);
              let n = bstr.length;
              const u8arr = new Uint8Array(n);
              while (n--) {
                u8arr[n] = bstr.charCodeAt(n);
              }
              const blob = new Blob([u8arr], { type: mime });
              
              const storageRef = ref(storage, `machine_screens/${user.uid}_${Date.now()}.jpg`);
              
              // Simple retry logic for storage upload
              let uploadSuccess = false;
              let retryCount = 0;
              const maxRetries = 3;
              let lastError = null;

              while (!uploadSuccess && retryCount < maxRetries) {
                try {
                  await uploadBytes(storageRef, blob);
                  uploadSuccess = true;
                } catch (e) {
                  retryCount++;
                  lastError = e;
                  console.warn(`Upload attempt ${retryCount} failed, retrying...`, e);
                  if (retryCount < maxRetries) {
                    await new Promise(resolve => setTimeout(resolve, 1000 * retryCount));
                  }
                }
              }

              if (!uploadSuccess) {
                throw lastError || new Error("Upload failed after retries");
              }

              return await getDownloadURL(storageRef);
            } catch (e) {
              console.error("Image upload failed", e);
              return '';
            }
          })();
        }

        // Wait for AI result first to show it to the user immediately
        const result = await analysisPromise;
        console.log("AI Analysis completed:", result ? "Success" : "Empty");
        setAnalysis(result.analysis || t.noResponse);
        setImprovementData(result.improvementData);
        if (result.productName && (!productName || productName === 'N/A')) {
          setProductName(result.productName);
        }
        setLoading(false); // Set loading to false as soon as we have the analysis

        // Update record with AI results in background
        const historyUpdate: Partial<AnalysisHistoryRecord> = {
          languageSelected: lang,
          inputMethod,
          machineCode: machineCode || '',
          technicalNote: notes,
          productName: (loadedData[0]?.product && loadedData[0].product !== 'N/A') ? loadedData[0].product : (result.productName || 'N/A'),
          rawInputData: JSON.stringify(loadedData),
          aiResultSummary: result.summary || result.analysis.substring(0, 200) + '...',
          aiRecommendations: result.recommendations || [],
          fullAnalysis: result.analysis,
          fullImprovementData: result.improvementData || undefined,
          inputCycle: result.improvementData?.before.cycleTime || 0,
          suggestedCycle: result.improvementData?.after.cycleTime || 0,
          reducedSeconds: (result.improvementData?.before.cycleTime || 0) - (result.improvementData?.after.cycleTime || 0),
          reducedPercent: (result.improvementData && result.improvementData.before.cycleTime > 0) ? 
            Math.round(((result.improvementData.before.cycleTime - result.improvementData.after.cycleTime) / result.improvementData.before.cycleTime) * 100) : 0,
          riskLevel: result.riskLevel || 'Medium',
          status: 'completed',
          processingTimeSec: (Date.now() - startTime) / 1000,
          confirmed: false,
          inputParams: {
            moldClose: (result.improvementData?.before.moldCloseTime || 0).toString(),
            injection: (result.improvementData?.before.injectionTime || 0).toString(),
            holding: (result.improvementData?.before.holdingTime || 0).toString(),
            cooling: (result.improvementData?.before.coolingTime || 0).toString(),
            charging: (result.improvementData?.before.chargingTime || 0).toString(),
            moldOpen: (result.improvementData?.before.moldOpenTime || 0).toString(),
            ejection: (result.improvementData?.before.ejectionTime || 0).toString(),
            pressure: (loadedData[0]?.injectionPressure || 0).toString(),
            temperature: (loadedData[0]?.meltTemp || 0).toString(),
            coolingTime: (loadedData[0]?.coolingTime || 0).toString(),
            speed: (loadedData[0]?.injectionSpeed || 0).toString(),
            material: loadedData[0]?.notes || 'N/A',
          }
        };

        if (recordId) {
          try {
            await updateDoc(doc(db, 'analysis_history', recordId), historyUpdate);
            setShowConfirmModal(true);
          } catch (error) {
            console.error("Initial update failed:", error);
          }
        }

        // Now wait for image upload to finish and update the record again
        const imageUrl = await imageUploadPromise;
        if (imageUrl && recordId) {
          try {
            await updateDoc(doc(db, 'analysis_history', recordId), { machineImageUrl: imageUrl });
          } catch (error) {
            console.error("Image URL update failed:", error);
          }
        }

      } catch (err) {
        setError(t.error);
        console.error("Analysis Error:", err);
        
        if (recordId) {
          try {
            await updateDoc(doc(db, 'analysis_history', recordId), {
              status: 'error',
              error: err instanceof Error ? err.message : String(err)
            });
          } catch (updateErr) {
            console.error("Error status update failed:", updateErr);
          }
        }
      }
    } finally {
      setLoading(false);
    }
  }, [user, userProfile, lang, t]);

  const handleSendMessage = async () => {
    if (!chatInput.trim() || !analysis) return;
    const userMsg: ChatMessage = { role: 'user', content: chatInput };
    setChatMessages(prev => [...prev, userMsg]);
    setChatInput('');
    setChatLoading(true);

    try {
      const reply = await chatWithExpert(analysis, rawContext, chatMessages, userMsg.content, lang);
      setChatMessages(prev => [...prev, { role: 'model', content: reply || t.expertReplyError }]);
    } catch (e) {
      setChatMessages(prev => [...prev, { role: 'model', content: t.connectionError }]);
    } finally {
      setChatLoading(false);
    }
  };

  const handleKeyDown = (e: React.KeyboardEvent) => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      handleSendMessage();
    }
  };

  useEffect(() => {
    chatEndRef.current?.scrollIntoView({ behavior: 'smooth' });
  }, [chatMessages, chatLoading]);

  const handleConfirmSave = async () => {
    if (!currentRecordId) return;
    setIsSaving(true);
    try {
      await updateDoc(doc(db, 'analysis_history', currentRecordId), {
        confirmed: true,
        confirmedAt: serverTimestamp()
      });
      setIsConfirmed(true);
      setShowConfirmModal(false);
      toast.success(t.saveSuccess);
    } catch (error) {
      handleFirestoreError(error, OperationType.UPDATE, 'analysis_history/' + currentRecordId);
      toast.error(t.saveError);
    } finally {
      setIsSaving(false);
    }
  };

  const reset = () => {
    setData([]);
    setAnalysis(null);
    setImprovementData(null);
    setProductName('');
    setError(null);
    setChatMessages([]);
    setIsConfirmed(false);
    setCurrentRecordId(null);
  };

  if (authLoading) {
    return (
      <div className="min-h-screen bg-ai-bg flex items-center justify-center">
        <div className="w-12 h-12 border-4 border-ai-accent border-t-transparent rounded-full animate-spin"></div>
      </div>
    );
  }

  if (!user) {
    return <Auth lang={lang} />;
  }

  return (
    <div className={`min-h-screen ${isDarkMode ? 'bg-ai-bg text-ai-text' : 'bg-slate-50 text-slate-900'} selection:bg-ai-accent/30 overflow-x-hidden`}>
      <Toaster position="top-right" theme={isDarkMode ? 'dark' : 'light'} />
      
      {/* Sidebar Overlay for Mobile */}
      {isSidebarOpen && (
        <div 
          className="fixed inset-0 bg-black/60 backdrop-blur-sm z-[60] lg:hidden"
          onClick={() => setIsSidebarOpen(false)}
        />
      )}

      {/* Sidebar */}
      <aside className={`fixed top-0 left-0 h-full bg-ai-surface border-r border-ai-border z-[70] transition-all duration-300 ease-in-out ${isSidebarOpen ? 'w-72 translate-x-0 shadow-2xl' : 'w-72 -translate-x-full lg:translate-x-0 lg:w-0 lg:border-none'} overflow-hidden`}>
        <div className="flex flex-col h-full w-72">
          <div className="p-6 border-b border-ai-border flex items-center justify-between bg-ai-surface/50">
            <div className="flex items-center gap-3">
              <div className="w-10 h-10 bg-gradient-to-br from-blue-600 to-blue-400 rounded-xl flex items-center justify-center shadow-lg shadow-blue-500/20">
                <Zap className="w-6 h-6 text-white fill-white" />
              </div>
              <div>
                <span className="font-black text-white tracking-tighter text-xl block leading-none">AI OPTIMIZE</span>
                <span className="text-[9px] font-bold text-ai-accent uppercase tracking-[0.3em] mt-1">Technical Intelligence</span>
              </div>
            </div>
            <button onClick={() => setIsSidebarOpen(false)} className="lg:hidden p-2 hover:bg-ai-accent/10 rounded-lg transition-all">
              <X className="w-6 h-6 text-ai-text-muted" />
            </button>
          </div>

          <nav className="flex-1 p-4 space-y-2 overflow-y-auto custom-scrollbar">
            <button 
              onClick={() => { setView('app'); reset(); setIsSidebarOpen(false); }}
              className={`w-full flex items-center gap-3 px-4 py-3 rounded-xl text-xs font-bold uppercase tracking-widest transition-all ${view === 'app' && !analysis ? 'bg-blue-600 text-white shadow-lg shadow-blue-600/20' : 'text-ai-text-muted hover:bg-ai-accent/10 hover:text-white'}`}
            >
              <Home className="w-5 h-5" />
              {t.newSession}
            </button>

            {userProfile?.role === 'admin' && (
              <button 
                onClick={() => { setView('admin'); setIsSidebarOpen(false); }}
                className={`w-full flex items-center gap-3 px-4 py-3 rounded-xl text-xs font-bold uppercase tracking-widest transition-all ${view === 'admin' ? 'bg-blue-600 text-white shadow-lg shadow-blue-600/20' : 'text-ai-text-muted hover:bg-ai-accent/10 hover:text-white'}`}
              >
                <LayoutDashboard className="w-5 h-5" />
                {t.adminDashboard}
              </button>
            )}

            <div className="pt-6 pb-2">
              <p className="px-4 text-[10px] font-bold text-ai-text-muted uppercase tracking-[0.2em] mb-3">{t.language}</p>
              <div className="grid grid-cols-1 gap-1">
                {(['vi', 'en', 'th', 'vi-en'] as Language[]).map((l) => (
                  <button
                    key={l}
                    onClick={() => setLang(l)}
                    className={`flex items-center justify-between px-4 py-3 rounded-xl text-xs font-bold transition-all ${lang === l ? 'bg-ai-accent/10 text-ai-accent border border-ai-accent/20' : 'text-ai-text-muted hover:bg-ai-accent/5'}`}
                  >
                    <span>{t[`lang${l.charAt(0).toUpperCase() + l.slice(1).replace('-', '')}` as keyof typeof t]}</span>
                    {lang === l && <div className="w-2 h-2 bg-ai-accent rounded-full shadow-[0_0_10px_rgba(59,130,246,0.8)]" />}
                  </button>
                ))}
              </div>
            </div>

            <div className="pt-6">
              <p className="px-4 text-[10px] font-bold text-ai-text-muted uppercase tracking-[0.2em] mb-3">Appearance</p>
              <button
                onClick={() => setIsDarkMode(!isDarkMode)}
                className="w-full flex items-center justify-between px-4 py-3 rounded-xl text-xs font-bold text-ai-text-muted hover:bg-ai-accent/5 transition-all"
              >
                <div className="flex items-center gap-3">
                  {isDarkMode ? <Sun className="w-5 h-5" /> : <Moon className="w-5 h-5" />}
                  <span>{isDarkMode ? t.lightMode : t.darkMode}</span>
                </div>
              </button>
            </div>
          </nav>

          <div className="p-4 border-t border-ai-border bg-ai-surface/30">
            <div className="flex items-center gap-3 p-3 bg-ai-bg/50 rounded-2xl border border-ai-border">
              <img src={userProfile?.photoURL} alt="" className="w-10 h-10 rounded-xl border border-ai-accent/20 shadow-sm" referrerPolicy="no-referrer" />
              <div className="flex-1 min-w-0">
                <p className="text-xs font-bold text-white truncate">{userProfile?.displayName}</p>
                <p className="text-[10px] text-ai-text-muted truncate">{userProfile?.email}</p>
              </div>
              <button onClick={() => auth.signOut()} className="p-2 text-red-500 hover:bg-red-500/10 rounded-lg transition-all" title={t.logout}>
                <LogOut className="w-5 h-5" />
              </button>
            </div>
          </div>
        </div>
      </aside>

      {/* Main Content Area */}
      <div className={`flex flex-col min-h-screen transition-all duration-300 ease-in-out ${isSidebarOpen ? 'lg:ml-72' : 'lg:ml-0'}`}>
        {/* Header */}
        <header className="bg-ai-surface/80 backdrop-blur-md border-b border-ai-border sticky top-0 z-50 h-20 flex items-center">
          <div className="w-full px-4 sm:px-6 flex items-center justify-between">
            <div className="flex items-center gap-4">
              <button 
                onClick={() => setIsSidebarOpen(!isSidebarOpen)}
                className="p-2.5 bg-ai-bg border border-ai-border rounded-xl text-ai-text-muted hover:text-ai-accent hover:border-ai-accent/30 transition-all shadow-sm"
              >
                <Menu className="w-6 h-6" />
              </button>
              <div className="flex items-center gap-3 group cursor-pointer" onClick={() => { setView('app'); reset(); }}>
                <div className="w-10 h-10 bg-gradient-to-br from-blue-600 to-blue-400 rounded-xl flex items-center justify-center shadow-lg shadow-blue-500/20 group-hover:scale-110 transition-transform">
                  <Zap className="w-6 h-6 text-white fill-white" />
                </div>
                <div className="hidden sm:block">
                  <h1 className="text-xl font-black text-white tracking-tighter leading-none">{t.title}</h1>
                  <p className="text-[10px] font-bold text-ai-accent uppercase tracking-[0.3em] mt-1">{t.subtitle}</p>
                </div>
              </div>
            </div>

            <div className="flex items-center gap-4">
              <div className="hidden lg:flex flex-col items-end">
                <span className="text-[10px] font-bold text-ai-text-muted uppercase tracking-widest leading-none">{t.location}</span>
                <span className="text-[9px] font-medium text-ai-accent/60 mt-1">{t.version}</span>
              </div>
              
              <div className="h-8 w-[1px] bg-ai-border mx-1 hidden sm:block" />

              <div className="flex items-center gap-3">
                <div className="hidden sm:flex flex-col items-end">
                  <span className="text-xs font-bold text-white leading-none">{user.displayName}</span>
                  <span className="text-[9px] text-ai-text-muted uppercase tracking-widest mt-1">{userProfile?.role}</span>
                </div>
                <img 
                  src={user.photoURL || ''} 
                  alt="Profile" 
                  className="w-10 h-10 rounded-xl border-2 border-ai-border hover:border-ai-accent transition-all cursor-pointer shadow-lg"
                  referrerPolicy="no-referrer"
                />
              </div>
            </div>
          </div>
        </header>

        {/* Main Content */}
        <main className={`flex-1 w-full mx-auto relative z-10 ${view === 'admin' ? 'p-4 sm:p-8' : 'max-w-7xl px-0 sm:px-6 py-8 sm:py-12'}`}>
        {view === 'admin' ? (
          <AdminDashboard lang={lang} userProfile={userProfile} onBack={() => setView('app')} />
        ) : (
          <>
            <div className="space-y-8">
              {!analysis && !loading ? (
                <div className="space-y-8 animate-fade-in">
                  <div className="px-4 sm:px-0">
                    <DataEntry 
                      onDataLoaded={handleDataLoaded} 
                      lang={lang} 
                      initialDepartment={userProfile?.department}
                    />
                  </div>
                  
                  <div className="grid grid-cols-1 md:grid-cols-3 gap-4 px-4 sm:px-0">
                    {[
                      { title: t.optimizeCycle, desc: t.optimizeCycleDesc, icon: '⏱️', color: 'blue' },
                      { title: t.captureParams, desc: t.captureParamsDesc, icon: '📸', color: 'emerald' },
                      { title: t.aiExpert, desc: t.aiExpertDesc, icon: '🤖', color: 'purple' }
                    ].map((item, i) => (
                      <div key={i} className="bg-ai-surface p-6 rounded-2xl border border-ai-border shadow-sm hover:shadow-xl hover:border-ai-accent/30 transition-all group cursor-default relative overflow-hidden">
                        <div className="absolute -right-8 -bottom-8 w-24 h-24 bg-ai-accent/5 blur-2xl rounded-full group-hover:bg-ai-accent/10 transition-all" />
                        <div className="flex items-center gap-4 relative z-10">
                          <div className="w-14 h-14 rounded-2xl bg-ai-bg border border-ai-border flex items-center justify-center text-3xl group-hover:scale-110 transition-transform shadow-inner">
                            {item.icon}
                          </div>
                          <div>
                            <h3 className="font-bold text-white text-sm uppercase tracking-wider">{item.title}</h3>
                            <p className="text-xs text-ai-text-muted mt-1 leading-relaxed">{item.desc}</p>
                          </div>
                        </div>
                      </div>
                    ))}
                  </div>
                </div>
              ) : (
                <div className="space-y-8 animate-fade-in">
                  <div className="sticky top-24 z-40 px-4 sm:px-0">
                    <div className="flex justify-between items-center bg-ai-surface/90 backdrop-blur-xl p-4 rounded-2xl shadow-2xl border border-ai-border">
                      <div className="flex items-center gap-4">
                        <div className="flex items-center gap-2.5">
                          <div className={`w-2.5 h-2.5 rounded-full ${loading ? 'bg-ai-accent animate-pulse shadow-[0_0_10px_var(--color-ai-accent)]' : 'bg-emerald-500 shadow-[0_0_10px_rgba(16,185,129,0.5)]'}`}></div>
                          <span className="text-xs font-black uppercase tracking-widest text-ai-accent">
                            {loading ? `${t.processing}...` : t.ready}
                          </span>
                        </div>
                        {!loading && (
                          <div className="hidden sm:flex items-center gap-2 px-3 py-1 bg-ai-bg rounded-lg border border-ai-border">
                            <span className="text-[10px] font-bold text-ai-text-muted uppercase tracking-widest">Product:</span>
                            <span className="text-[10px] font-black text-white uppercase truncate max-w-[150px]">{productName || 'N/A'}</span>
                          </div>
                        )}
                      </div>
                      <div className="flex items-center gap-3">
                        {!loading && (
                          <button 
                            onClick={() => setShowConfirmModal(true)}
                            disabled={isConfirmed || isSaving}
                            className={`px-4 py-2 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all ${
                              isConfirmed 
                                ? 'bg-emerald-500/10 text-emerald-500 border border-emerald-500/20' 
                                : 'bg-blue-600 text-white hover:bg-blue-500 shadow-lg shadow-blue-600/20'
                            }`}
                          >
                            {isSaving ? 'Saving...' : isConfirmed ? 'Saved to Admin' : 'Confirm & Save'}
                          </button>
                        )}
                        <button 
                          onClick={reset}
                          className="p-2 bg-ai-bg border border-ai-border rounded-xl text-ai-text-muted hover:text-red-500 hover:border-red-500/30 transition-all"
                          title={t.newSession}
                        >
                          <X className="w-5 h-5" />
                        </button>
                      </div>
                    </div>
                  </div>

                  <div className="grid grid-cols-1 lg:grid-cols-3 gap-8 px-4 sm:px-0">
                    <div className="lg:col-span-2 space-y-8">
                      {improvementData && (
                        <div className="bg-ai-surface rounded-3xl shadow-2xl border border-ai-border overflow-hidden">
                          <Visualizations 
                            data={data} 
                            improvementData={improvementData} 
                            lang={lang} 
                            productName={productName}
                          />
                        </div>
                      )}

                      <div className="bg-ai-surface rounded-3xl shadow-2xl border border-ai-border overflow-hidden group">
                        <div className="bg-ai-surface/50 border-b border-ai-border px-8 py-6 flex items-center justify-between">
                          <h3 className="text-lg font-black text-white tracking-tight flex items-center gap-3">
                            <div className="p-2 bg-blue-500/10 rounded-lg">
                              <FileText className="w-5 h-5 text-blue-500" />
                            </div>
                            {t.optimizationReport}
                          </h3>
                        </div>
                        <div className={`p-8 prose ${isDarkMode ? 'prose-invert' : ''} prose-blue max-w-none text-ai-text leading-relaxed`}>
                          {loading ? (
                            <div className="space-y-6 animate-pulse">
                              {[1, 2, 3, 4, 5, 6].map(i => (
                                <div key={i} className={`h-4 ${isDarkMode ? 'bg-ai-bg' : 'bg-slate-200'} rounded-full w-full`} style={{ width: `${100 - (i * 5)}%` }}></div>
                              ))}
                            </div>
                          ) : error ? (
                            <div className="p-6 bg-red-500/10 text-red-500 border border-red-500/20 rounded-2xl flex items-center gap-4">
                              <AlertCircle className="w-6 h-6 shrink-0" />
                              <p className="font-bold">{error}</p>
                            </div>
                          ) : (
                            <ReactMarkdown>{analysis || ''}</ReactMarkdown>
                          )}
                        </div>
                      </div>
                    </div>

                    <div className="lg:col-span-1">
                      <div className="bg-ai-surface rounded-3xl shadow-2xl border border-ai-border flex flex-col h-[700px] sticky top-48 overflow-hidden group">
                        <div className="absolute -top-32 -right-32 w-64 h-64 bg-ai-accent/5 blur-[100px] rounded-full group-hover:bg-ai-accent/10 transition-all duration-700"></div>
                        <div className="bg-ai-surface/50 border-b border-ai-border px-6 py-5 font-black text-white flex items-center gap-3 relative z-10">
                           <div className="p-2 bg-ai-accent/10 rounded-lg">
                             <Zap className="w-5 h-5 text-ai-accent fill-ai-accent" />
                           </div>
                           <span className="uppercase tracking-widest text-xs">{t.aiAssistant}</span>
                        </div>
                        <div className={`flex-1 overflow-y-auto p-6 space-y-6 custom-scrollbar ${isDarkMode ? 'bg-ai-bg/30' : 'bg-slate-50/50'}`}>
                          {chatMessages.length === 0 && (
                            <div className="h-full flex flex-col items-center justify-center text-center p-8 space-y-4">
                              <div className="w-16 h-16 bg-ai-accent/10 rounded-2xl flex items-center justify-center">
                                <Zap className="w-8 h-8 text-ai-accent" />
                              </div>
                              <p className="text-sm text-ai-text-muted font-medium">{lang === 'vi' ? 'Hỏi tôi bất cứ điều gì về kỹ thuật ép phun!' : 'Ask me anything about injection molding!'}</p>
                            </div>
                          )}
                          {chatMessages.map((msg, i) => (
                            <div key={i} className={`flex ${msg.role === 'user' ? 'justify-end' : 'justify-start'} animate-fade-in`}>
                              <div className={`max-w-[90%] rounded-2xl px-5 py-3.5 text-sm shadow-sm leading-relaxed ${
                                msg.role === 'user' 
                                  ? 'bg-blue-600 text-white shadow-blue-600/20 rounded-tr-none' 
                                  : `${isDarkMode ? 'bg-ai-surface text-blue-100 border border-ai-border' : 'bg-white text-slate-800 border border-slate-200'} rounded-tl-none`
                              }`}>
                                 {msg.role === 'model' ? (
                                    <div className={`prose ${isDarkMode ? 'prose-invert' : ''} prose-sm prose-blue max-w-none`}>
                                      <ReactMarkdown>{msg.content}</ReactMarkdown>
                                    </div>
                                  ) : msg.content}
                              </div>
                            </div>
                          ))}
                          {chatLoading && (
                            <div className="flex items-center gap-3 text-[10px] text-ai-accent font-black uppercase tracking-[0.2em] animate-pulse">
                              <div className="flex gap-1">
                                <div className="w-1.5 h-1.5 bg-ai-accent rounded-full"></div>
                                <div className="w-1.5 h-1.5 bg-ai-accent rounded-full animate-bounce [animation-delay:-0.3s]"></div>
                                <div className="w-1.5 h-1.5 bg-ai-accent rounded-full animate-bounce [animation-delay:-0.15s]"></div>
                              </div>
                              {t.thinking}
                            </div>
                          )}
                          <div ref={chatEndRef} />
                        </div>
                        <div className="p-6 border-t border-ai-border bg-ai-surface/50">
                          <div className="flex gap-3">
                            <input 
                              type="text" 
                              value={chatInput}
                              onChange={e => setChatInput(e.target.value)}
                              onKeyDown={handleKeyDown}
                              placeholder={t.chatPlaceholder}
                              className="flex-1 bg-ai-bg border border-ai-border rounded-xl px-4 py-3.5 text-sm text-white focus:ring-2 focus:ring-ai-accent/40 outline-none transition-all placeholder:text-ai-text-muted/50"
                            />
                            <button 
                              onClick={handleSendMessage} 
                              disabled={!chatInput.trim() || chatLoading}
                              className="bg-ai-accent hover:bg-ai-accent/80 disabled:opacity-50 disabled:cursor-not-allowed text-white p-3.5 rounded-xl transition-all shadow-lg shadow-ai-accent/20"
                            >
                               <svg className="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                 <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M12 19l9-2-9-18-9 18 9-2zm0 0v-8" />
                               </svg>
                            </button>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              )}
            </div>
          </>
        )}
      </main>

        <footer className="bg-ai-surface border-t border-ai-border py-12 relative z-10">
          <div className="max-w-7xl mx-auto px-6 text-center">
            <div className="flex items-center justify-center gap-3 mb-6">
              <div className="w-8 h-8 bg-ai-bg border border-ai-border rounded-lg flex items-center justify-center">
                <Zap className="w-5 h-5 text-ai-text-muted" />
              </div>
              <span className="font-black text-white tracking-tighter text-lg">AI OPTIMIZE</span>
            </div>
            <p className="text-xs text-ai-text-muted font-medium uppercase tracking-widest">{t.footer}</p>
          </div>
        </footer>
      </div>

      {/* Confirmation Modal */}
      <AnimatePresence>
        {showConfirmModal && (
          <div className="fixed inset-0 z-[100] flex items-center justify-center p-4">
            <motion.div
              initial={{ opacity: 0 }}
              animate={{ opacity: 1 }}
              exit={{ opacity: 0 }}
              onClick={() => setShowConfirmModal(false)}
              className="absolute inset-0 bg-black/60 backdrop-blur-sm"
            />
            <motion.div
              initial={{ opacity: 0, scale: 0.9, y: 20 }}
              animate={{ opacity: 1, scale: 1, y: 0 }}
              exit={{ opacity: 0, scale: 0.9, y: 20 }}
              className="bg-ai-surface border border-ai-border rounded-3xl shadow-2xl w-full max-w-md overflow-hidden relative z-10"
            >
              <div className="p-8">
                <div className="w-16 h-16 bg-blue-500/10 rounded-2xl flex items-center justify-center mb-6">
                  <CheckCircle className="w-8 h-8 text-blue-500" />
                </div>
                <h3 className="text-xl font-black text-white mb-3 tracking-tight">
                  {t.confirmSaveTitle}
                </h3>
                <p className="text-ai-text-muted text-sm leading-relaxed mb-8">
                  {t.confirmSaveContent}
                </p>
                <div className="flex gap-3">
                  <button
                    onClick={() => setShowConfirmModal(false)}
                    className="flex-1 px-6 py-3.5 rounded-xl text-xs font-bold uppercase tracking-widest text-ai-text-muted hover:bg-ai-accent/5 border border-ai-border transition-all"
                  >
                    {t.cancel}
                  </button>
                  <button
                    onClick={handleConfirmSave}
                    disabled={isSaving}
                    className="flex-1 px-6 py-3.5 rounded-xl text-xs font-bold uppercase tracking-widest bg-blue-600 text-white hover:bg-blue-500 shadow-lg shadow-blue-600/20 transition-all flex items-center justify-center gap-2"
                  >
                    {isSaving ? (
                      <div className="w-4 h-4 border-2 border-white/30 border-t-white rounded-full animate-spin" />
                    ) : (
                      t.confirmOk
                    )}
                  </button>
                </div>
              </div>
            </motion.div>
          </div>
        )}
      </AnimatePresence>
    </div>
  );
};

export default App;
